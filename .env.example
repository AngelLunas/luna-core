# Example environment variables read by luna_core.core.config.Settings.
# luna-core is a library; the host application is responsible for actually
# loading these values into the process environment.

# Application
APP_NAME=Luna Core
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://luna:luna@localhost:5432/luna_core
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (rate limiter, run-event pub/sub, Celery broker default)
REDIS_URL=redis://localhost:6379/0

# Security — 32+ char secret required
JWT_SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=180
REFRESH_TOKEN_EXPIRE_DAYS=30

# Credential encryption (Fernet) — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-a-base64-fernet-key-32-bytes

# Cookies
REFRESH_COOKIE_NAME=luna_refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_DOMAIN=

# Rate limiting
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Celery — defaults to REDIS_URL for both broker and backend if unset
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_DEFAULT_QUEUE=luna_core

# Run-event pub/sub
RUN_EVENT_CHANNEL_PREFIX=luna_core:run_events

# CORS — host app may pass through to its FastAPI app
CORS_ORIGINS=[]
